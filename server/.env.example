# Copy this file to ".env" in the same folder (server/.env) and fill in your real values.
# Get these from: Supabase Dashboard → Project Settings → API

# Your project URL, e.g. https://abcdefghijk.supabase.co
SUPABASE_URL=

# "service_role" secret key (NOT the "anon public" key).
# This key bypasses Row Level Security, so it must only ever live on the server.
# Never expose it in frontend code or commit a real value to git.
SUPABASE_SERVICE_ROLE_KEY=

# Port the Node server listens on (Render sets this automatically in production)
PORT=3000
